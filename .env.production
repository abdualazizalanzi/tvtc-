# Sample environment variables for production
# Copy this to .env and fill in your values

# Database Connection - UPDATE THIS
DATABASE_URL=postgresql://username:password@localhost:5432/skillrecord

# Session Secret - Generate a random string (use: openssl rand -base64 32)
SESSION_SECRET=change-this-to-a-random-secret-string

# Node Environment
NODE_ENV=production

# Server Port
PORT=5000

